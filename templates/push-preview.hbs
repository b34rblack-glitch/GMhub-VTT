{{!--
  templates/push-preview.hbs
  ===========================================================================
  GMhub VTT Bridge — PushPreviewDialog body.

  Rendered by `ui.js#PushPreviewDialog`. Shown before `pushAll` so the
  GM can sanity-check the scope of the upcoming sync. Two-tier layout:

    1. Counts table (left = category, right = count)
    2. Expandable <details> sections listing the individual rows by
       name. Closed by default to keep the dialog compact; opened on
       demand for verification.

  GMV-9 (v0.4.4) added the per-session breakdown — see the inline
  comment below for the rationale.
--}}
<div class="gmhub-push-preview">
  {{!-- Empty state: nothing to push. Hides every other affordance
       and disables the Confirm button below. --}}
  {{#if empty}}
    <p class="gmhub-empty-state">{{localize "GMHUB.Dialog.PushPreview.Empty"}}</p>
  {{else}}
    <p>{{localize "GMHUB.Dialog.PushPreview.Body"}}</p>
    {{!-- Counts table — each row is only rendered when the
         corresponding bucket is non-empty so unused rows don't add
         noise. --}}
    <table class="gmhub-push-preview-counts">
      <tbody>
        {{#if entitiesCreate.length}}
          <tr>
            <th>{{localize "GMHUB.Dialog.PushPreview.EntitiesCreate"}}</th>
            <td>{{entitiesCreate.length}}</td>
          </tr>
        {{/if}}
        {{#if entitiesUpdate.length}}
          <tr>
            <th>{{localize "GMHUB.Dialog.PushPreview.EntitiesUpdate"}}</th>
            <td>{{entitiesUpdate.length}}</td>
          </tr>
        {{/if}}
        {{#if notesCreate.length}}
          <tr>
            <th>{{localize "GMHUB.Dialog.PushPreview.NotesCreate"}}</th>
            <td>{{notesCreate.length}}</td>
          </tr>
        {{/if}}
        {{#if notesUpdate.length}}
          <tr>
            <th>{{localize "GMHUB.Dialog.PushPreview.NotesUpdate"}}</th>
            <td>{{notesUpdate.length}}</td>
          </tr>
        {{/if}}
        {{!-- Session-plan row: comma-joined field list (e.g.
             "gm_notes, agenda"). --}}
        {{#if sessionPlanLabel}}
          <tr>
            <th>{{localize "GMHUB.Dialog.PushPreview.SessionPlan"}}</th>
            <td>{{sessionPlanLabel}}</td>
          </tr>
        {{/if}}
        {{#if quickNotes}}
          <tr>
            <th>{{localize "GMHUB.Dialog.PushPreview.QuickNotes"}}</th>
            <td>{{quickNotes}}</td>
          </tr>
        {{/if}}
      </tbody>
    </table>

    {{!-- Expandable details: entities about to be created. Useful to
         spot accidental new entries (e.g. a duplicate due to a naming
         collision). --}}
    {{#if entitiesCreate.length}}
      <details>
        <summary>{{localize "GMHUB.Dialog.PushPreview.EntitiesCreateList"}}</summary>
        <ul>
          {{#each entitiesCreate}}
            <li><code>{{this.kind}}</code> &mdash; {{this.name}}</li>
          {{/each}}
        </ul>
      </details>
    {{/if}}
    {{!-- Same idea for entities about to be PATCH-updated. --}}
    {{#if entitiesUpdate.length}}
      <details>
        <summary>{{localize "GMHUB.Dialog.PushPreview.EntitiesUpdateList"}}</summary>
        <ul>
          {{#each entitiesUpdate}}
            <li><code>{{this.kind}}</code> &mdash; {{this.name}}</li>
          {{/each}}
        </ul>
      </details>
    {{/if}}
    {{!-- And notes about to be PATCH-updated. Note: notes about to
         be *created* don't get their own details panel because they
         tend to be edited from the web app, not Foundry. --}}
    {{#if notesUpdate.length}}
      <details>
        <summary>{{localize "GMHUB.Dialog.PushPreview.NotesUpdateList"}}</summary>
        <ul>
          {{#each notesUpdate}}
            <li>{{this.name}}</li>
          {{/each}}
        </ul>
      </details>
    {{/if}}
    {{!-- v0.4.4: per-session breakdown when more than one session journal is
         dirty. Closes GMV-9. The aggregated sessionPlanLabel above tells the
         GM *which fields* will be pushed; this list tells them *which
         sessions* are affected. Hidden when only zero or one session is
         queued (the SessionPlan row already conveys that case). --}}
    {{#if sessionPlanJournals.length}}
      <details>
        <summary>{{localize "GMHUB.Dialog.PushPreview.SessionPlanJournalsList"}} ({{sessionPlanJournals.length}})</summary>
        <ul>
          {{#each sessionPlanJournals}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
      </details>
    {{/if}}
  {{/if}}

  {{!-- Confirm row. Confirm is disabled when there's nothing to
       push so the GM can't fire an empty Push and waste a round-trip. --}}
  <footer class="gmhub-dialog-buttons">
    <button type="button" data-action="cancel">
      <i class="fas fa-times"></i> {{localize "GMHUB.Button.Cancel"}}
    </button>
    <button type="button" data-action="confirm" {{#if empty}}disabled{{/if}}>
      <i class="fas fa-cloud-upload-alt"></i> {{localize "GMHUB.Dialog.PushPreview.Confirm"}}
    </button>
  </footer>
</div>
