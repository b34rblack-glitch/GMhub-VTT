<div class="gmhub-lifecycle-confirm">
  <p>{{localize bodyKey}}</p>
  <footer class="gmhub-dialog-buttons">
    <button type="button" data-action="cancel">
      <i class="fas fa-times"></i> {{localize "GMHUB.Button.Cancel"}}
    </button>
    <button type="button" data-action="confirm" class="gmhub-confirm-destructive">
      <i class="fas fa-check"></i> {{localize confirmKey}}
    </button>
  </footer>
</div>
