<div class="gmhub-sync">
  <section class="gmhub-info">
    <p><strong>{{localize "GMHUB.Dialog.BaseUrlLabel"}}</strong> {{baseUrl}}</p>
    <p><strong>{{localize "GMHUB.Dialog.CampaignIdLabel"}}</strong>
      {{#if campaignId}}<code>{{campaignId}}</code>{{else}}<em>{{localize "GMHUB.Dialog.NotSet"}}</em>{{/if}}
    </p>
    <p><strong>{{localize "GMHUB.Dialog.ActiveSessionLabel"}}</strong>
      {{#if activeSessionId}}<code>{{activeSessionId}}</code>{{else}}<em>{{localize "GMHUB.Dialog.NotSet"}}</em>{{/if}}
    </p>
    <p><strong>{{localize "GMHUB.Dialog.LastPullLabel"}}</strong> {{lastPullAt}}</p>
  </section>

  {{#unless campaignId}}
    <section class="gmhub-empty">
      <p>{{localize "GMHUB.Dialog.NoCampaignBody"}}</p>
      <button type="button" data-action="open-settings">
        <i class="fas fa-cog"></i> {{localize "GMHUB.Button.OpenSettings"}}
      </button>
    </section>
  {{else}}
    {{#unless activeSessionId}}
      <section class="gmhub-empty">
        <p>{{localize "GMHUB.Dialog.NoSessionBody"}}</p>
        <button type="button" data-action="pick-session">
          <i class="fas fa-list"></i> {{localize "GMHUB.Button.PickSession"}}
        </button>
      </section>
    {{/unless}}

    {{#if activeSessionId}}
      <section class="gmhub-lifecycle">
        <p class="gmhub-lifecycle-state">
          <strong>{{localize "GMHUB.Dialog.SessionStateLabel"}}</strong>
          {{#if sessionStatus}}
            <code>{{sessionStatus}}</code>
          {{else if sessionStatusError}}
            <em>{{localize "GMHUB.Dialog.SessionStateUnknown"}}</em>
          {{else}}
            <em>{{localize "GMHUB.Dialog.SessionStateLoading"}}</em>
          {{/if}}
        </p>
        {{#if anyLifecycleVisible}}
          <div class="gmhub-lifecycle-buttons">
            {{#if lifecycle.start}}
              <button type="button" data-action="session-start" {{#if lifecycleBusy}}disabled{{/if}}>
                <i class="fas fa-play"></i> {{localize "GMHUB.Button.SessionStart"}}
              </button>
            {{/if}}
            {{#if lifecycle.pause}}
              <button type="button" data-action="session-pause" {{#if lifecycleBusy}}disabled{{/if}}>
                <i class="fas fa-pause"></i> {{localize "GMHUB.Button.SessionPause"}}
              </button>
            {{/if}}
            {{#if lifecycle.resume}}
              <button type="button" data-action="session-resume" {{#if lifecycleBusy}}disabled{{/if}}>
                <i class="fas fa-play"></i> {{localize "GMHUB.Button.SessionResume"}}
              </button>
            {{/if}}
            {{#if lifecycle.end}}
              <button type="button" data-action="session-end" {{#if lifecycleBusy}}disabled{{/if}}>
                <i class="fas fa-stop"></i> {{localize "GMHUB.Button.SessionEnd"}}
              </button>
            {{/if}}
          </div>
        {{/if}}
      </section>
    {{/if}}

    <section class="gmhub-actions">
      <button type="button" data-action="ping">
        <i class="fas fa-plug"></i> {{localize "GMHUB.Button.TestConnection"}}
      </button>
      <button type="button" data-action="pull" {{#unless activeSessionId}}disabled{{/unless}}>
        <i class="fas fa-cloud-download-alt"></i> {{localize "GMHUB.Button.Pull"}}
      </button>
      <button type="button" data-action="push" {{#unless activeSessionId}}disabled{{/unless}}>
        <i class="fas fa-cloud-upload-alt"></i> {{localize "GMHUB.Button.Push"}}
      </button>
      <button type="button" data-action="pick-session">
        <i class="fas fa-list"></i> {{localize "GMHUB.Button.PickSession"}}
      </button>
    </section>
  {{/unless}}

  {{#if status}}
    <section class="gmhub-status"><p>{{status}}</p></section>
  {{/if}}

  <pre data-role="sync-output" class="gmhub-output">{{output}}</pre>
</div>
