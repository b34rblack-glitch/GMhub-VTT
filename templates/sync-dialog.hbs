<div class="gmhub-sync">
  <section class="gmhub-info">
    <p><strong>Base URL:</strong> {{baseUrl}}</p>
    <p><strong>API key:</strong> {{#if hasKey}}configured{{else}}<em>missing</em>{{/if}}</p>
    <p><strong>Last pull:</strong> {{lastPullAt}}</p>
  </section>

  <section class="gmhub-actions">
    <button type="button" data-action="ping"><i class="fas fa-plug"></i> Test connection</button>
    <button type="button" data-action="push-all"><i class="fas fa-cloud-upload-alt"></i> Push all journals</button>
    <button type="button" data-action="pull-all"><i class="fas fa-cloud-download-alt"></i> Pull all journals</button>
  </section>

  {{#if status}}
    <section class="gmhub-status"><p>{{status}}</p></section>
  {{/if}}

  {{#if result}}
    <section class="gmhub-result">
      <h3>Last {{result.kind}} result</h3>
      <ul>
        {{#if result.isPush}}<li>Pushed: {{result.pushed}}</li>{{/if}}
        {{#if result.isPull}}<li>Pulled: {{result.pulled}}</li>{{/if}}
        <li>Failed: {{result.failed}}</li>
      </ul>
      {{#if result.errors.length}}
        <details>
          <summary>Errors ({{result.errors.length}})</summary>
          <ul>
            {{#each result.errors}}
              <li><strong>{{this.name}}:</strong> {{this.message}}</li>
            {{/each}}
          </ul>
        </details>
      {{/if}}
    </section>
  {{/if}}
</div>
